# Required for Teacher Mode
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional – local Ollama
OLLAMA_HOST=http://localhost:11434

# Dream Mode limits
DAILY_DREAM_LIMIT=50
DREAM_MODE_ENABLED=true

# Paths (will be overridden by Drive mount in Colab)
SQLITE_PATH=./prd_llm.db
UPLOAD_DIR=./uploads
CHECKPOINT_DIR=./checkpoints

# Microservice URLs (inside Colab they are on localhost)
PRD_CORE_URL=http://localhost:8001
AGENTS_URL=http://localhost:8002
PRIVATE_LLM_URL=http://localhost:8000

# Advanced feature flags
ENABLE_META_LEARNING=true
ENABLE_SELF_CORRECTION=true
ENABLE_SYNTHETIC_DATA=true
ENABLE_CROSS_DOMAIN_SYNTHESIS=true
ENABLE_IMPLICIT_FEEDBACK=true
ENABLE_CURIOSITY=true
